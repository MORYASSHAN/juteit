{
  "name": "juteit-monorepo",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm -r --parallel start",
    "build": "pnpm -r --if-present run build",
    "install-all": "pnpm install",
    "clean": "pnpm -r exec rm -rf node_modules dist"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  }
}